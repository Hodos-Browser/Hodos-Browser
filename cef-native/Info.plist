<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>${MACOSX_BUNDLE_EXECUTABLE_NAME}</string>
	<key>CFBundleIdentifier</key>
	<string>com.hodosbrowser.app</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>${MACOSX_BUNDLE_BUNDLE_NAME}</string>
	<key>CFBundleIconFile</key>
	<string>hodos.icns</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>${MACOSX_BUNDLE_SHORT_VERSION_STRING}</string>
	<key>CFBundleVersion</key>
	<string>${MACOSX_BUNDLE_BUNDLE_VERSION}</string>
	<key>LSMinimumSystemVersion</key>
	<string>11.0</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSSupportsAutomaticGraphicsSwitching</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Hodos Browser needs camera access for websites that request it, such as video calls.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Hodos Browser needs microphone access for websites that request it, such as video calls and voice recording.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Hodos Browser needs location access for websites that request it, such as maps and local search.</string>
	<key>SUFeedURL</key>
	<string>https://hodosbrowser.com/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>GVq3mpDl8eelsG0A5wqC5FBYZd3fy7U3we9iZ9+Tq3Q=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<!-- Fixlist E: how often Sparkle runs its scheduled background update check.
	     Without this key Sparkle uses a ~1-day default, so on retest neither Automatic
	     (silent) nor Notify fired within the test window — the check simply wasn't due.
	     3 hours = Chrome-like: prompt in production and testable in minutes. Sparkle also
	     checks on launch when this interval has elapsed since the last check, so a running
	     or relaunched Mac picks up a published update within a few hours instead of a day.
	     (This controls the CHECK cadence; the Automatic-vs-Notify mode still governs what
	     happens when an update is found — silent install-on-quit vs prompt.) -->
	<key>SUScheduledCheckInterval</key>
	<integer>10800</integer>
</dict>
</plist>
